{
  "query": "SELECT \n  u.name as corretor,\n  i.tipo,\n  i.createdAt,\n  DATE(i.createdAt) as data_criacao,\n  i.leadId,\n  l.nome as lead_nome\nFROM interacoes i\nINNER JOIN users u ON i.corretorId = u.id\nLEFT JOIN leads l ON i.leadId = l.id\nWHERE i.tipo = 'whatsapp'\n  AND (u.name LIKE '%Andrew%' OR u.name LIKE '%Leticia%' OR u.name LIKE '%Letícia%')\nORDER BY i.createdAt DESC\nLIMIT 100;",
