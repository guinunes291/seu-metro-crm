{
  "query": "\nSELECT \n  i.leadId,\n  i.corretorId,\n  u.name as corretor_nome,\n  i.tipo,\n  DATE(i.createdAt) as data,\n  COUNT(*) as total_registros,\n  MIN(i.createdAt) as primeiro_registro,\n  MAX(i.createdAt) as ultimo_registro,\n  TIMESTAMPDIFF(SECOND, MIN(i.createdAt), MAX(i.createdAt)) as diferenca_segundos\nFROM interacoes i\nJOIN users u ON i.corretorId = u.id\nWHERE DATE(i.createdAt) >= DATE_SUB(CURDATE(), INTERVAL 30 DAY)\nGROUP BY i.leadId, i.corretorId, i.tipo, DATE(i.createdAt)\nHAVING COUNT(*) > 1 AND TIMESTAMPDIFF(SECOND, MIN(i.createdAt), MAX(i.createdAt)) < 60\nORDER BY total_registros DESC, data DESC\nLIMIT 20;\n",
