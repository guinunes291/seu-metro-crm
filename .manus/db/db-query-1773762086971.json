{
  "query": "\n-- Corretores com detalhes completos\nSELECT u.id, u.name, u.email, u.role, u.status,\n  COUNT(DISTINCT l.id) as total_leads,\n  SUM(CASE WHEN l.status = 'em_atendimento' THEN 1 ELSE 0 END) as em_atendimento,\n  SUM(CASE WHEN l.status = 'contrato_fechado' THEN 1 ELSE 0 END) as contratos,\n  SUM(CASE WHEN l.status = 'perdido' THEN 1 ELSE 0 END) as perdidos\nFROM users u\nLEFT JOIN leads l ON l.corretorId = u.id\nWHERE u.role IN ('corretor', 'gerente', 'admin')\nGROUP BY u.id, u.name, u.email, u.role, u.status\nORDER BY u.role, contratos DESC, total_leads DESC;\n",
