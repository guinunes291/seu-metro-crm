  "query": "\n-- Buscar leads com padrões de teste\nSELECT id, nome, telefone, email, status, corretorId, createdAt\nFROM leads\nWHERE \n  nome LIKE '%Teste%' \n  OR nome LIKE '%Lead Rank%'\n  OR nome LIKE '%Roleta%'\n  OR nome LIKE '%Webhook%'\n  OR telefone LIKE '11777777777%'\n  OR telefone LIKE '11888888888%'\n  OR telefone LIKE '11992%'\n  OR email LIKE '%webhook%'\nORDER BY createdAt DESC\nLIMIT 100;\n",
