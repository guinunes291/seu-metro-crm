{
  "query": "\n-- Verificar distribution_log de hoje por corretor\nSELECT \n  dl.corretorId,\n  u.name,\n  COUNT(*) as total_log,\n  COUNT(DISTINCT dl.leadId) as leads_unicos,\n  MIN(dl.createdAt) as primeiro,\n  MAX(dl.createdAt) as ultimo\nFROM distribution_log dl\nJOIN users u ON u.id = dl.corretorId\nWHERE dl.createdAt >= DATE_SUB(NOW(), INTERVAL 24 HOUR)\nGROUP BY dl.corretorId, u.name\nORDER BY total_log DESC\nLIMIT 15;\n",
