  "query": "SELECT \n  lh.id,\n  lh.tipo,\n  lh.createdAt,\n  DATE(lh.createdAt) as data_criacao,\n  FROM_UNIXTIME(1768539600000/1000) as inicio_hoje_calculado,\n  FROM_UNIXTIME(1768625999999/1000) as fim_hoje_calculado,\n  CASE \n    WHEN lh.createdAt >= FROM_UNIXTIME(1768539600000/1000) AND lh.createdAt <= FROM_UNIXTIME(1768625999999/1000) THEN 'SIM'\n    ELSE 'NÃO'\n  END as esta_no_intervalo\nFROM lead_history lh\nJOIN users u ON lh.corretorId = u.id\nWHERE (u.name LIKE '%Leticia%' OR u.name LIKE '%Letícia%')\n  AND lh.tipo IN ('ligacao', 'whatsapp')\nORDER BY lh.createdAt DESC\nLIMIT 10;",
